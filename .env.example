# Database
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:PORT/railway

# Meta Ads
META_ACCESS_TOKEN=your_long_lived_access_token
META_AD_ACCOUNT_ID=act_123456789
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret

# Zoho Books
ZOHO_CLIENT_ID=your_client_id
ZOHO_CLIENT_SECRET=your_client_secret
ZOHO_REFRESH_TOKEN=your_refresh_token
ZOHO_ORG_ID=878028611
ZOHO_BANK_ACCOUNT_ID=6038376000000095011

# Nuport
NUPORT_API_KEY=dYaAxa5pemfxDYd3Oop1y4suYvd4MFDW

# Telegram (daily briefing + reorder alerts)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_personal_chat_id

# Winterfell Agent — Claude + WooCommerce
# Reuses the same WC_URL / WC_CONSUMER_KEY / WC_CONSUMER_SECRET as the WooCommerce sync.
ANTHROPIC_API_KEY=your_anthropic_api_key
WC_URL=https://winterfell.com.bd
WC_CONSUMER_KEY=your_woocommerce_consumer_key
WC_CONSUMER_SECRET=your_woocommerce_consumer_secret

# WordPress Application Password (wp-admin > Users > Profile > Application
# Passwords) — needed for image uploads (wp/v2/media is a WP-core endpoint,
# the WooCommerce keys above don't work for it).
WP_USERNAME=your_wp_admin_username
WP_APP_PASSWORD=your_generated_application_password

# Optional — separate bot for the Winterfell Agent so it doesn't mix into the
# daily briefing / reorder chat. Falls back to TELEGRAM_BOT_TOKEN/CHAT_ID above
# if left unset.
AGENT_TELEGRAM_BOT_TOKEN=your_second_bot_token_from_botfather
AGENT_TELEGRAM_CHAT_ID=your_chat_id_with_that_bot

# ── Customer Support Agent ───────────────────────────────────────────────────
# Separate Anthropic key from the product agent's ANTHROPIC_API_KEY above, so the
# CS workload bills and rate-limits independently.
CS_ANTHROPIC_API_KEY=your_separate_cs_anthropic_api_key
# OpenAI is used ONLY for product-image embeddings (Anthropic has no embeddings API).
OPENAI_API_KEY=your_openai_api_key
# Below this cosine similarity the image match asks the customer to confirm.
SIMILARITY_THRESHOLD=0.82

# Facebook / Instagram (Messenger) webhooks
FB_PAGE_ACCESS_TOKEN=your_fb_page_access_token
FB_VERIFY_TOKEN=winterfell_cs_2026
FB_APP_SECRET=your_fb_app_secret          # optional — enables X-Hub-Signature check
IG_ACCESS_TOKEN=your_ig_access_token      # falls back to FB_PAGE_ACCESS_TOKEN

# WhatsApp via WATI
WATI_API_KEY=your_wati_api_key
WATI_ENDPOINT=https://live-server-xxxxx.wati.io

# Handoff alerts (Telegram). CS_TELEGRAM_BOT_TOKEN falls back to AGENT_/TELEGRAM_BOT_TOKEN.
CS_TELEGRAM_BOT_TOKEN=your_cs_bot_token
RAFID_TELEGRAM_ID=your_telegram_chat_id
TUMPA_TELEGRAM_ID=tumpa_chat_id
NAFIZ_TELEGRAM_ID=nafiz_chat_id
AYON_TELEGRAM_ID=ayon_chat_id

# Self-learning (nightly_learner) — all optional, sane defaults shown
CS_LEARNER_LOOKBACK_HOURS=48        # only consider conversations updated within this window
CS_LEARNER_QUIET_MINUTES=60         # skip conversations still active in the last N minutes
CS_LEARNER_MAX_CONVERSATIONS=200    # cap per run
CS_LEARNER_MAX_MEMORIES=8           # cap on distilled notes injected into the system prompt

# App
PORT=3000
APP_PASSWORD=winterfell2024
